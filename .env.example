# Copy this file to .env and fill in your own key. .env is gitignored — never commit real secrets.

# Required for Task 3 (AI Failure Explainer). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional overrides. Default model is Opus for best-quality failure analysis;
# swap to claude-haiku-4-5 if you want cheaper/faster analysis on high-volume CI runs.
ANTHROPIC_MODEL=claude-opus-4-8
UI_BASE_URL=https://opensource-demo.orangehrmlive.com
API_BASE_URL=https://dummyjson.com
