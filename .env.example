# Copy this file to .env. No cloud API key needed — Task 3 (AI Failure Explainer) runs
# against a local Ollama model.
#
# Setup:
#   1. Install Ollama: https://ollama.com/download
#   2. Pull a model:   ollama pull llama3.2
#   3. Make sure the server is running (the installer starts it automatically; otherwise
#      run `ollama serve`).

# Optional overrides — defaults match a standard local Ollama install.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

UI_BASE_URL=https://opensource-demo.orangehrmlive.com
API_BASE_URL=https://dummyjson.com
