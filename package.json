{
  "name": "testmu-sdet1-abhay",
  "version": "1.0.0",
  "description": "AI-native QA regression suite for TestMu AI SDET-1 assessment: Playwright + TypeScript test generation and LLM-powered failure analysis.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=ui-chromium --headed",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "ajv": "^8.20.0"
  }
}
